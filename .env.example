# Shopify Storefront API — fill these in to connect the live backend.
# Until set, the site renders with built-in auto-generated demo products.

# Your store domain, e.g. libersens.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Storefront API public access token
# (Shopify admin → Settings → Apps → Develop apps → create app → Storefront API)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
